# Phone number (digits only, international format, no "+") that you send
# pinned messages to. Defaults to 971564949243 if not set.
TARGET_PHONE_NUMBER=971564949243

# n8n webhook URL that will receive JSON payloads: { from, text, timestamp }
N8N_WEBHOOK_URL=https://your-n8n-instance.example.com/webhook/whatsapp-obsidian

# Dropbox API access token, used to persist/restore the Baileys auth_info
# session so Railway redeploys don't require a fresh QR scan every time.
DROPBOX_ACCESS_TOKEN=your-dropbox-access-token-here

# Optional: path in Dropbox where the zipped session is stored.
DROPBOX_SESSION_PATH=/whatsapp-obsidian/auth_info.zip

# Optional: Baileys/pino log verbosity (fatal, error, warn, info, debug, trace)
LOG_LEVEL=info
